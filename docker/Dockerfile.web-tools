# 构建上下文：仓库根目录
#   docker build -f docker/Dockerfile.web-tools -t agent-tools-frontend:latest .

# -----------------------------------------------------------------------------
# Stage 1: 构建 Vite 前端（envDir 为 frontend 上级目录，需在 /app 写入 .env）
# 默认 API 基路径为 /hub/api/v1：浏览器走同源 /hub/api/...，Nginx 剥 /hub 后反代到后端 /api/...
# 覆盖示例：--build-arg VITE_API_BASE_URL=/api/v1
# -----------------------------------------------------------------------------
FROM node:20-alpine AS builder

ARG VITE_API_BASE_URL=/hub/api/v1
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

WORKDIR /app

# Vite loadEnv 从 frontend 的上一级加载；构建时注入 VITE_* 到该文件
RUN printf '%s\n' "VITE_API_BASE_URL=${VITE_API_BASE_URL}" > .env

COPY frontend/package.json frontend/package-lock.json ./frontend/
WORKDIR /app/frontend
RUN npm ci

COPY frontend ./

RUN npm run build

# -----------------------------------------------------------------------------
# Stage 2：Nginx 托管静态资源；/api/ 反代由环境变量 BACKEND_URL + BACKEND_PORT 配置（与 agent-studio 一致）
# 官方镜像会对 /etc/nginx/templates/*.template 做 envsubst
# -----------------------------------------------------------------------------
FROM nginx:alpine

COPY --from=builder /app/frontend/dist /usr/share/nginx/html/hub

COPY frontend/nginx/nginx.conf /etc/nginx/nginx.conf
COPY frontend/nginx/default.conf.template /etc/nginx/templates/default.conf.template

# 默认值：无后端时仍可启动；访问宿主机上的 API 请改为 host.docker.internal 等
ENV BACKEND_URL=localhost
ENV BACKEND_PORT=8100

RUN chown -R nginx:nginx /usr/share/nginx/html

EXPOSE 9002

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -q -O- http://127.0.0.1:9002/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
