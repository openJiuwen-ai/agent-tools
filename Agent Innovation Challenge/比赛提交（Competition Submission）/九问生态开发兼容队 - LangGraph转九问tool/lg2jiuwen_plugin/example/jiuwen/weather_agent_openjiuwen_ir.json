          "error"
        ],
        "is_conditional": false,
        "condition_returns": [],
        "uses_llm": false,
        "body": "def call_weather(state: AgentState) -> AgentState:\n    \"\"\"直接调用天气工具获取结果\"\"\"\n    city = state.get('city')\n    date = state.get('date')\n    if not city or not date:\n        state['error'] = '缺少城市或日期参数'\n        return state\n    result = get_weather.invoke({'city': city, 'date': date})\n    print('weather result:', result)\n    state['weather'] = result\n    return state"
      }
