# OpenJiuwen market_place (example)
#
# =============================================================================
# MARKET_PLACE SERVICE
# =============================================================================
STORE_HOST=0.0.0.0
STORE_PORT=8100

# 可选：显式指定数据库连接串（优先级最高）
# STORE_DB_URL=sqlite:///./data/store.db

# =============================================================================
# DB_TYPE 支持 mysql 或留空走 SQLite（由 STORE_DB_URL / 默认值决定）
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=

# 可选：给 store 单独的库名（仅当 DB_TYPE=mysql 时生效）
STORE_DB_NAME=openjiuwen_market

# 鉴权服务（Bearer 校验时请求的地址）
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=8000

# System admin（与请求头 X-System-Token 比对，二选一鉴权时使用）
SYSTEM_ADMIN_TOKEN=""

# 对象存储：仅支持 MinIO | OBS。本地部署默认 MinIO，云端部署选 OBS
# 说明：OBS/MinIO 统一使用 MARKET_S3_* 变量名
STORAGE_TYPE=MinIO
MARKET_BUCKET_NAME=openjiuwen-market
MARKET_S3_ENDPOINT=http://localhost:9000
MARKET_S3_ACCESS_KEY=
MARKET_S3_SECRET_KEY=
# 可选：S3 区域（默认 us-east-1）
MARKET_S3_REGION=us-east-1
# 可选：显式覆盖 SSL
# - MinIO 默认推断为 false
# - OBS 默认推断为 true（如需可手动填 true/false）
MARKET_S3_USE_SSL=
# 公开桶访问地址，用于生成 icon_uri 等前端可访问 URL；不填则用 endpoint+bucket
MARKET_STORAGE_PUBLIC_URL=http://localhost:9000/openjiuwen-market

