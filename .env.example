# openJiuwen market_place (example)
#
# =============================================================================
# MARKET_PLACE SERVICE
# =============================================================================

# -----------------------------------------------------------------------------
# [服务基础配置]
# 必填
# -----------------------------------------------------------------------------
STORE_HOST=0.0.0.0
STORE_PORT=8100

# -----------------------------------------------------------------------------
# [数据库配置]
# 必填（DB_TYPE 当前仅支持 mysql）
# -----------------------------------------------------------------------------
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
STORE_DB_NAME=openjiuwen_market
# 可选：整串覆盖（与 DB_TYPE 拼装二选一），
# STORE_DB_URL=mysql+pymysql://user:password@localhost:3306/openjiuwen_market?charset=utf8mb4

# -----------------------------------------------------------------------------
# [鉴权配置]
# 必填：Bearer 校验依赖该服务
# -----------------------------------------------------------------------------
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=8000

# 可选：与请求头 X-System-Token 比对（二选一鉴权时使用）
SYSTEM_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# [对象存储配置]
# 仅支持 MinIO | OBS（本地默认 MinIO，云端常用 OBS）
# -----------------------------------------------------------------------------
# 必填：对象存储基础项
STORAGE_TYPE=MinIO
MARKET_BUCKET_NAME=openjiuwen-market
MARKET_S3_ENDPOINT=http://localhost:9000
# static（MinIO 默认 / OBS 可显式）：永久 AK/SK
MARKET_S3_ACCESS_KEY=
MARKET_S3_SECRET_KEY=

# 凭证模式：未设置时 MinIO 默认 static，OBS 默认 dynamic
# MARKET_CREDENTIALS_MODE=
# OBS static：仅用上方 MARKET_S3_* 永久密钥
# OBS dynamic：用下方 HUAWEICLOUD_* 调 IAM 接口获取临时 AK/SK（无需填 MARKET_S3_*）
# 可选：IAM 临时凭证会话时长（秒），默认 3600。OBS dynamic 时建议 ≥ MARKET_S3_PRESIGNED_EXPIRES（默认 1800，且不超过云上限）
# MARKET_S3_STS_DURATION_SECONDS=3600

# 必填（OBS）/可选（MinIO）：S3 区域
MARKET_S3_REGION=

# 可选：显式覆盖 SSL
# - MinIO 默认推断为 false
# - OBS 默认推断为 true（如需可手动填 true/false）
MARKET_S3_USE_SSL=

# 可选：GET 预签名有效期（秒），默认 1800（30 分钟）；范围见 s3_storage_client
# MARKET_S3_PRESIGNED_EXPIRES=1800

# -----------------------------------------------------------------------------
# [敏感信息加解密配置（AES + HuaweiCloud KMS）]
# -----------------------------------------------------------------------------
# - SERVER_AES_MASTER_KEY: Base64 编码的 32 字节 AES 根密钥
SERVER_AES_MASTER_KEY=

# --- KMS Config for Secret Protection
# 是否启用 KMS 模式（True/False）
HUAWEICLOUD_KMS_ENABLED=False
# 华为云IAM配置
HUAWEICLOUD_USERNAME=your_username
HUAWEICLOUD_DOMAIN_NAME=your_domain
HUAWEICLOUD_IAM_ENDPOINT=

# 华为云项目配置
HUAWEICLOUD_PROJECT_NAME=your_project_name
HUAWEICLOUD_PROJECT_ID=your_project_id
HUAWEICLOUD_REGION=your_region

# 华为云KMS配置
HUAWEICLOUD_KMS_KEY_ID=your_kms_key_id
HUAWEICLOUD_KMS_ENDPOINT=
HUAWEICLOUD_KMS_ENCRYPTION_ALGORITHM=RSAES_OAEP_SHA_256

SECURITY_APPLICATION_SECRET_CACHE_ENABLED=true
SECURITY_APPLICATION_SECRET_CACHE_TTL_SECONDS=60

# =============================================================================
# FRONTEND (plugin market, Vite)
# =============================================================================
# 前端端口
FRONTEND_PORT=9002

# 前端请求 API 的基础路径（Vite 环境变量，仅构建/开发时注入到产物）。
# - 不设置或留空时，代码内默认使用 /api/v1（适合 Nginx 将 /api 反代到 marketplace）。
# - 若需直连完整后端地址，可设为绝对 URL，例如 http://localhost:8100/api/v1。
# - Docker 镜像构建时也可用 --build-arg VITE_API_BASE_URL=... 覆盖。
# VITE_API_BASE_URL=

# 开发时与 marketplace 监听端口一致（见 STORE_PORT，默认 8100）
VITE_API_PROXY_TARGET=http://localhost:8100